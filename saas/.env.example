# ============================================================
# MakOne SaaS Control Plane — Environment Variables
# Copy to .env and fill in before running setup-saas.sh
# ============================================================

# Domain (no https://, no trailing slash)
BASE_DOMAIN=makone-bi.com

# Email for Let's Encrypt SSL certificates
CERTBOT_EMAIL=your@email.com

# OpenAI key shared across all customer instances (swap to per-customer billing later)
OPENAI_API_KEY=sk-proj-...

# Admin panel password for /admin
ADMIN_PASSWORD=choose-a-strong-password

# Flask session secret (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET=your-secret-here

# Stripe (leave blank to run in dev/no-payment mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# Paths (defaults work if you follow the setup-saas.sh guide)
APP_DIR=/opt/makone/app
CUSTOMERS_DIR=/opt/makone/customers
NGINX_SITES=/etc/nginx/sites-enabled
MAKONE_IMAGE=makone-app:latest

# SaaS control plane port (Nginx proxies 80/443 → this)
SAAS_PORT=3000
