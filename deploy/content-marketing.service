[Unit]
Description=AI Content Marketing App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/ai-content-marketing
ExecStart=/home/ubuntu/ai-content-marketing/venv/bin/python main.py start
Restart=on-failure
RestartSec=60
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
