# ==========================================
# AI Content Marketing App - Configuration
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- HeyGen (Avatar Videos) ---
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=           # Your clone avatar ID (find in HeyGen dashboard)
HEYGEN_VOICE_ID=            # Your cloned voice ID (find in HeyGen dashboard)

# --- Google AI (VEO 3 videos + Gemini Imagen 3 images) ---
# One key powers both: VEO 3 video generation AND Imagen 3 image generation
GOOGLE_API_KEY=             # From Google AI Studio (aistudio.google.com)
GOOGLE_PROJECT_ID=          # Your GCP project ID (for Vertex AI)

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=      # OAuth2 bearer token (3-month expiry, needs refresh)
LINKEDIN_PERSON_URN=        # urn:li:person:XXXXXXX  (personal profile posting)
LINKEDIN_ORG_URN=           # urn:li:organization:XXXXXXX  (company page posting)
                            # Leave blank the one you don't use

# --- Facebook ---
FACEBOOK_ACCESS_TOKEN=      # Long-lived Page Access Token
FACEBOOK_PAGE_ID=           # Your Facebook Page ID (numbers only)

# --- Business Info ---
BUSINESS_NAME=Your AI Automation Company
BUSINESS_WEBSITE=https://yourwebsite.com
CONTACT_EMAIL=contact@yourcompany.com

# --- SMTP (Error Email Notifications) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=              # Gmail: use App Password (not your main password)

# --- Schedule ---
POST_HOUR=9                 # 24h format, UTC by default
POST_DAYS=mon,wed,fri       # Comma-separated: mon,tue,wed,thu,fri,sat,sun
